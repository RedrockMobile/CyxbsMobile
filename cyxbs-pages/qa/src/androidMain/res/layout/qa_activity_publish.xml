<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/qa_publish_background_color"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/qa_publish_ll_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/qa_publish_btn_back"
            android:layout_width="7dp"
            android:layout_height="16dp"
            android:src="@drawable/qa_ic_arrow_back" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/qa_publish_btn_publish"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:background="@drawable/qa_shape_btn_publish_background"
            android:text="@string/qa_string_publish"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/qa_publish_et_question"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="32dp"
        android:background="@null"
        android:gravity="start|top"
        android:hint="@string/qa_publish_edit_hint"
        android:inputType="textMultiLine"
        android:textColor="@color/qa_text_title_color"
        android:textColorHint="@color/qa_text_content_color"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/qa_publish_rv_tag_selector"
        app:layout_constraintTop_toBottomOf="@id/qa_publish_ll_toolbar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/qa_publish_rv_tag_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!--这是用来展示已有问题的RV，默认先Gone-->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/qa_publish_rv_question_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/qa_publish_rv_tag_selector"
        app:layout_constraintTop_toBottomOf="@id/qa_publish_ll_toolbar" />


</androidx.constraintlayout.widget.ConstraintLayout>