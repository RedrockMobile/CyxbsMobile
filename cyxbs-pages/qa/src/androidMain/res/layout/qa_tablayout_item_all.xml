<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/qa_tv_tl_tab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="全部"
        android:textColor="@color/qa_text_title_color"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/qa_dot_view"
        android:layout_width="16dp"
        android:layout_height="12dp"
        android:text="20+"
        android:textSize="9sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="-8dp"
        android:layout_marginStart="-1dp"
        android:visibility="gone"
        android:background="@drawable/qa_shape_home_btn_publish_background"
        app:layout_constraintStart_toEndOf="@id/qa_tv_tl_tab"
        app:layout_constraintBottom_toTopOf="@id/qa_tv_tl_tab"
        />
</androidx.constraintlayout.widget.ConstraintLayout>
