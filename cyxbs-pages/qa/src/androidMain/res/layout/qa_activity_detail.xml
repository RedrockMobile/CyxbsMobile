<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/qa_publish_background_color"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/qa_detail_ll_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:padding="5dp"
            android:id="@+id/qa_detail_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/qa_ic_arrow_back" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/qa_detail_btn_publish"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:background="@drawable/qa_shape_btn_publish_background"
            android:text="@string/qa_string_publish"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <ImageView
        android:visibility="gone"
        android:id="@+id/qa_detail_iv_no_net"
        android:src="@drawable/qa_ic_detail_no_net"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/qa_detail_tv_no_net"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/qa_detail_iv_no_net"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/qa_text_content_color"
        android:text="@string/qa_detail_no_net"
        android:textSize="16sp"/>

    <ScrollView
        android:scrollbars="none"
        android:id="@+id/qa_detail_sv_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/qa_detail_ll_toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/qa_detail_iv_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:src="@drawable/qa_ic_publish_question_card_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/qa_detail_tv_question"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:drawablePadding="10dp"
                android:text="@string/qa_loading"
                android:textColor="@color/qa_text_title_color"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/qa_detail_iv_icon"
                app:layout_constraintTop_toTopOf="@+id/qa_detail_iv_icon" />

            <TextView
                android:id="@+id/qa_detail_tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="2025.07.27"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@+id/qa_detail_tv_question"
                app:layout_constraintTop_toBottomOf="@+id/qa_detail_tv_question" />

            <TextView
                android:id="@+id/qa_detail_tv_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/qa_shape_publish_tag_selected_bg"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingTop="2dp"
                android:paddingEnd="10dp"
                android:paddingBottom="2dp"
                android:text="新生类"
                android:textColor="@color/qa_publish_tag_selected_text_color"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="@id/qa_detail_tv_time"
                app:layout_constraintTop_toBottomOf="@id/qa_detail_tv_time" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/qa_detail_ll_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/qa_shape_publish_question_card_bg"
                app:layout_constraintTop_toBottomOf="@id/qa_detail_tv_tag"
                tools:layout_editor_absoluteX="0dp">

                <ImageView
                    android:id="@+id/qa_detail_iv_point"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="23dp"
                    android:src="@drawable/qa_ic_publish_question_card_point"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/qa_detail_tv_answer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="15dp"
                    android:text="@string/qa_loading"
                    android:textColor="@color/qa_text_content_color"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/qa_detail_iv_point"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/qa_detail_iv_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/qa_ic_publish_question_card_bg"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/qa_detail_tv_answer" />

                <ImageView
                    android:id="@+id/qa_detail_iv_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="5dp"
                    android:layout_marginTop="23dp"
                    android:layout_marginEnd="41dp"
                    android:src="@drawable/qa_ic_publish_question_card_like"
                    app:layout_constraintEnd_toEndOf="@+id/qa_detail_iv_bg"
                    app:layout_constraintTop_toTopOf="@+id/qa_detail_iv_bg" />

                <TextView
                    android:id="@+id/qa_detail_tv_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="21dp"
                    android:layout_marginStart="-5dp"
                    android:layout_marginBottom="14dp"
                    android:text="2000"
                    android:textColor="@color/qa_text_content_color"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/qa_detail_iv_like"
                    app:layout_constraintStart_toEndOf="@id/qa_detail_iv_like" />

                <ImageView
                    android:id="@+id/qa_detail_iv_look"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="54dp"
                    android:src="@drawable/qa_ic_detail_looked"
                    app:layout_constraintBottom_toBottomOf="@id/qa_detail_iv_like"
                    app:layout_constraintEnd_toStartOf="@id/qa_detail_iv_like" />

                <TextView
                    android:id="@+id/qa_detail_tv_looked_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="13dp"
                    android:text="10000"
                    android:textColor="@color/qa_text_content_color"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/qa_detail_iv_look"
                    app:layout_constraintStart_toEndOf="@id/qa_detail_iv_look" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>