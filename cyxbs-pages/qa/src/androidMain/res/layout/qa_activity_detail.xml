<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:overScrollMode="never">
  <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

      <androidx.cardview.widget.CardView
          android:id="@+id/qaCardview"
          android:layout_width="match_parent"
          android:layout_height="105dp"
          app:layout_constraintTop_toTopOf="parent">

          <androidx.constraintlayout.widget.ConstraintLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent">

              <ImageView
                  android:id="@+id/qa_de_return"
                  android:layout_width="7dp"
                  android:layout_height="16dp"
                  android:layout_marginStart="18dp"
                  android:layout_marginTop="59dp"
                  android:src="@drawable/qa_ic_arrow_back"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent" />

              <Button
                  android:id="@+id/qa_de_btn"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginEnd="16dp"
                  android:layout_marginTop="53dp"
                  android:background="@drawable/qa_shape_btn_publish_background"
                  android:minWidth="0dp"
                  android:minHeight="0dp"
                  android:paddingLeft="16dp"
                  android:paddingTop="4dp"
                  android:paddingRight="16dp"
                  android:paddingBottom="4dp"
                  android:text="发布"
                  android:textColor="@color/qa_btn_color"
                  android:textSize="14sp"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintTop_toTopOf="parent" />

          </androidx.constraintlayout.widget.ConstraintLayout>
      </androidx.cardview.widget.CardView>

      <TextView
          android:id="@+id/qa_de_tv"
          android:layout_width="201dp"
          android:layout_height="wrap_content"
          android:text="这里是问题?"
          android:textSize="22sp"
          android:textColor="@color/qa_text_title_color"
          android:drawableStart="@drawable/qa_ic_problem"
          android:drawablePadding="10dp"
          android:layout_marginStart="16dp"
          app:layout_constraintTop_toBottomOf="@+id/qaCardview"
          app:layout_constraintStart_toStartOf="parent"/>


      <com.google.android.flexbox.FlexboxLayout
          android:id="@+id/qa_de_tags"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          android:layout_marginTop="6dp"
          app:flexDirection="row"
          app:flexWrap="wrap"
          app:justifyContent="flex_start"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toEndOf="@+id/qa_de_tv"
          app:layout_constraintTop_toBottomOf="@+id/qaCardview" />



      <TextView
          android:id="@+id/qa_de_time"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="2025.2.2"
          android:textSize="17sp"
          android:textColor="@color/qa_text_content_color"
          android:layout_marginTop="8dp"
          android:layout_marginStart="48dp"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@+id/qa_de_tv" />
      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginHorizontal="16dp"
          android:layout_marginTop="20dp"
          android:background="@color/qa_de_card_background_color"
          app:cardCornerRadius="4dp"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@+id/qa_de_time">

          <androidx.constraintlayout.widget.ConstraintLayout
              android:layout_width="match_parent"
              android:layout_height="match_parent">
              <ImageView
                  android:id="@+id/qa_de_point"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="16dp"
                  android:layout_marginTop="23dp"
                  android:src="@drawable/qa_ic_publish_question_card_point"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent"/>

              <TextView
                  android:id="@+id/qa_de_content"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="48dp"
                  android:layout_marginTop="16dp"
                  android:text="这是答案"
                  android:textColor="@color/qa_text_content_color"
                  android:textSize="16sp"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent" />

              <ImageView
                  android:id="@+id/qa_de_look"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="213dp"
                  android:layout_marginBottom="16dp"
                  android:layout_marginTop="32dp"
                  android:src="@drawable/qa_ic_de_looked"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toBottomOf="@+id/qa_de_content" />

              <TextView
                  android:id="@+id/qa_de_lookcount"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="13dp"
                  android:text="2000"
                  android:textColor="@color/qa_text_content_color"
                  android:textSize="12sp"
                  app:layout_constraintBottom_toBottomOf="@+id/qa_de_look"
                  app:layout_constraintStart_toEndOf="@+id/qa_de_look" />
              <ImageView
                  android:id="@+id/qa_de_bg"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:src="@drawable/qa_ic_publish_question_card_bg"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"/>

              <ImageView
                  android:id="@+id/qa_de_like"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="30dp"
                  android:layout_marginTop="25dp"
                  android:layout_marginBottom="16dp"
                  android:src="@drawable/qa_ic_publish_question_card_like"
                  app:layout_constraintBottom_toBottomOf="@+id/qa_de_bg"
                  app:layout_constraintStart_toStartOf="@+id/qa_de_bg"
                  app:layout_constraintTop_toTopOf="@+id/qa_de_bg" />

              <TextView
                  android:id="@+id/qa_de_likecount"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginBottom="13dp"
                  android:text="2000"
                  android:textColor="@color/qa_text_content_color"
                  android:textSize="12sp"
                  app:layout_constraintBottom_toBottomOf="@+id/qa_de_like"
                  app:layout_constraintStart_toEndOf="@+id/qa_de_like" />




          </androidx.constraintlayout.widget.ConstraintLayout>











      </androidx.cardview.widget.CardView>





  </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>