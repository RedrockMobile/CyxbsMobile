<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/qa_publish_background_color"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/qa_home_iv_return"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="4dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/qa_ic_arrow_back"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/qa_home_tv_title"
        android:layout_width="85dp"
        android:layout_height="31dp"
        android:layout_marginTop="16dp"
        android:text="Q and A"
        android:textColor="@color/qa_text_title_color"
        android:textSize="23sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <com.google.android.material.tabs.TabLayout
        android:id="@+id/qa_home_tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@android:color/transparent"
        android:theme="@style/Theme.MaterialComponents"
        app:tabIndicator="@drawable/qa_ic_tab_indicator"
        app:tabIndicatorColor="@android:color/transparent"
        app:tabIndicatorFullWidth="true"
        app:tabIndicatorHeight="3dp"
        app:tabRippleColor="@android:color/transparent"
        app:tabTextAppearance="@style/qa_TabTextAppearance"
        app:tabMinWidth="0dp"
        app:tabPaddingBottom="0dp"
        app:tabPaddingEnd="0dp"
        app:tabPaddingStart="0dp"
        app:tabPaddingTop="0dp"
        app:layout_constraintTop_toBottomOf="@id/qa_home_tv_title"/>

    <EditText
        android:id="@+id/qa_home_btn_search"
        android:layout_width="333dp"
        android:layout_height="38dp"
        android:background="@drawable/qa_shape_search_background"
        android:hint="搜索关键词"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingLeft="20dp"
        android:textColorHint="@color/qa_search_content_color"
        android:textColor="@color/qa_search_content_color"
        android:textSize="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/qa_home_tab_layout" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/qa_home_vp2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@id/qa_home_btn_publish"
        app:layout_constraintTop_toBottomOf="@id/qa_home_btn_search" />

    <LinearLayout
        android:id="@+id/qa_home_btn_publish"
        android:layout_width="163dp"
        android:layout_height="41dp"
        android:layout_marginBottom="44dp"
        android:background="@drawable/qa_shape_home_btn_publish_background"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="30dp"
        android:paddingEnd="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="21dp"
            android:src="@drawable/qa_ic_publish_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="发布问题"
            android:textColor="@color/qa_btn_color"
            android:textSize="18dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>